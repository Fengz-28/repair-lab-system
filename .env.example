# App
APP_ENV=development
APP_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
ADMIN_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://repairlab:repairlab_password@localhost:5432/repairlab?schema=public

# Auth placeholder
AUTH_SECRET=replace-with-local-secret
SESSION_COOKIE_NAME=repair_lab_session
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-local-admin-password
ADMIN_NAME=Admin

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_PUBLIC_WINDOW_SECONDS=60
RATE_LIMIT_PUBLIC_MAX_REQUESTS=120
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# Storage placeholder
STORAGE_PROVIDER=local
PRIVATE_STORAGE_ROOT=./storage/private
STORAGE_PUBLIC_BASE_URL=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Email
# EMAIL_PROVIDER supports: console, resend, disabled
EMAIL_PROVIDER=console
EMAIL_FROM="Repair Lab <no-reply@example.com>"
EMAIL_PROVIDER_KEY=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# WhatsApp placeholder
WHATSAPP_PROVIDER=disabled
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Google Calendar placeholder
GOOGLE_CALENDAR_PROVIDER=disabled
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
GOOGLE_CALENDAR_ID=

# n8n placeholder
N8N_ENABLED=false
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=replace-with-local-webhook-secret

# Ollama / AI placeholder
AI_PROVIDER=disabled
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=
OLLAMA_EMBEDDING_MODEL=

# Optional Trello placeholder
TRELLO_PROVIDER=disabled
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
