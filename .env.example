# App
APP_ENV=development
APP_URL=http://localhost:3001
PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
ADMIN_ALLOWED_ORIGINS=http://localhost:3001

# Database
DATABASE_URL=postgresql://repairlab:repairlab_password@localhost:5432/repairlab?schema=public
# Optional override used only by docker-compose app service.
# Leave empty to use postgres:5432 inside the Docker network.
DOCKER_DATABASE_URL=

# Auth placeholder
AUTH_SECRET=replace-with-local-secret
SESSION_COOKIE_NAME=repair_lab_session
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-local-admin-password
ADMIN_NAME=Admin

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_PUBLIC_WINDOW_SECONDS=60
RATE_LIMIT_PUBLIC_MAX_REQUESTS=120
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# Storage placeholder
STORAGE_PROVIDER=local
PRIVATE_STORAGE_ROOT=./storage/private
STORAGE_PUBLIC_BASE_URL=
MAX_UPLOAD_FILE_SIZE_MB=10
MAX_UPLOAD_FILES_PER_INTAKE=12
MAX_UPLOAD_FILES_PER_TICKET=8
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=


# WhatsApp placeholder
WHATSAPP_PROVIDER=disabled
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Google Calendar placeholder
GOOGLE_CALENDAR_PROVIDER=disabled
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
GOOGLE_CALENDAR_ID=

# n8n placeholder
N8N_ENABLED=false
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=replace-with-local-webhook-secret

# IntegrationEvent outbox worker
INTEGRATION_WORKER_BATCH_SIZE=10
INTEGRATION_WORKER_MAX_RETRIES=5
INTEGRATION_WORKER_STALE_PROCESSING_MINUTES=15

# Local backup helper
POSTGRES_CONTAINER_NAME=repair_lab_postgres
BACKUP_FRESHNESS_HOURS=72

# Ollama / AI placeholder
AI_PROVIDER=disabled
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=
OLLAMA_EMBEDDING_MODEL=

# Optional Trello placeholder
TRELLO_PROVIDER=disabled
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=

# Email
# EMAIL_PROVIDER supports: resend, console, disabled
# Keep EMAIL_NOTIFICATIONS_ENABLED=false and EMAIL_DRY_RUN=true until DNS/provider setup is verified.
EMAIL_PROVIDER=resend
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_DRY_RUN=true
EMAIL_FROM="FengzLab <updates@example.com>"
EMAIL_REPLY_TO=contacto@example.com
EMAIL_PROVIDER_KEY=
RESEND_API_KEY=replace-with-resend-api-key
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
PUBLIC_CONTACT_EMAIL=contacto@example.com
NEXT_PUBLIC_CONTACT_EMAIL=contacto@example.com
NEXT_PUBLIC_WHATSAPP_ENABLED=false
NEXT_PUBLIC_WHATSAPP_NUMBER=
